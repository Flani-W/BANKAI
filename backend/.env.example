# ---- Backend env (login-only service) ----
# Copy to .env and fill in. NEVER commit .env. JWT_SECRET and the Mongo URI are secret.

PORT=8787

# MongoDB connection string.
#   Local:  mongodb://localhost:27017
#   Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=bankai

# Secret used to sign/verify JWT access tokens. Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-a-long-random-secret
# Token lifetime (zeit/ms format: '7d', '12h', '30m', or seconds as a number).
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed frontend origins (CORS allow-list; never use *)
CORS_ORIGINS=http://localhost:5173
