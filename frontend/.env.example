# Frontend env. Copy to .env. Only VITE_* values are exposed to the browser — never put secrets here.
VITE_API_BASE_URL=http://localhost:8787

# Dev-only: set to 'true' to explore the app WITHOUT a backend/database (auto signs you in
# as a guest). Leave unset/false for any real build — it bypasses the login gate.
# VITE_DEV_BYPASS_AUTH=true
